# ══════════════════════════════════════════════════
#  VARIABLES DE ENTORNO — Bot WhatsApp MMH
#  Copia este archivo como ".env" y llena los valores
# ══════════════════════════════════════════════════

# ── Meta / WhatsApp Cloud API ──────────────────────
# Lo obtienes en: developers.facebook.com > Tu App > WhatsApp > Configuración de API
WHATSAPP_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PHONE_NUMBER_ID=1234567890123456

# Token secreto que TÚ inventas (cualquier texto, ej: "mmh_bot_secreto_2024")
# Este mismo valor lo pegas en Meta al configurar el webhook
WEBHOOK_VERIFY_TOKEN=mmh_bot_secreto_2024

# ── Firebase Admin SDK ────────────────────────────
# Lo obtienes en: Firebase Console > Configuración del proyecto > Cuentas de servicio
# > Generar nueva clave privada  (descarga el .json y copia los valores)
FIREBASE_PROJECT_ID=mis-manos-hablaran-44e17
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@mis-manos-hablaran-44e17.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAAS...\n-----END PRIVATE KEY-----\n"

# ── Puerto (Railway lo asigna automáticamente, no cambiar) ──
PORT=3000
